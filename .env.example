# IdentityService Configuration
IDENTITY_SERVICE_URL=http://localhost:8080
IDENTITY_SERVICE_JWKS_URL=http://localhost:8080/.well-known/jwks.json

# OAuth2 Client for Web App
OAUTH_CLIENT_ID=incident-management-web
OAUTH_CLIENT_SECRET=super-secret-client-secret

# Scopes
OAUTH_SCOPES=api:incidents:read,api:incidents:write,api:incidents:manage,api:incidents:admin,api:users:read,api:users:write,api:notifications:read,api:notifications:write,api:analytics:read

# Database URLs (for services)
INCIDENT_DB_URL=postgresql://postgres:password@localhost:5432/incident_db
USER_DB_URL=postgresql://postgres:password@localhost:5433/user_db
NOTIFICATION_DB_URL=postgresql://postgres:password@localhost:5434/notification_db
ANALYTICS_DB_URL=postgresql://postgres:password@localhost:5435/analytics_db

# Services
NOTIFICATION_SERVICE_URL=http://localhost:3004

# RabbitMQ
RABBITMQ_URL=amqp://admin:password@localhost:5672

# Mail (Mailtrap)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
MAIL_TO_OVERRIDE=notifications@example.com

# Logging
LOG_LEVEL=info